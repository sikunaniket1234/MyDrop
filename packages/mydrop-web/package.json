{
  "name": "@mydrop/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx serve src",
    "build": "tsc -p tsconfig.json && node -e \"require('fs').cpSync('src/index.html','dist/index.html'); require('fs').cpSync('src/manifest.json','dist/manifest.json')\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings 0",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  }
}
